---
import Layout from "../layouts/Layout.astro";
import { site } from "../config/site";
---

<Layout title="문의" description={`${site.name} 상담 문의 — 전화·이메일·온라인 폼으로 연락 가능.`}>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-700">Contact</p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900">
        편한 채널로 연락 주세요
      </h1>
      <p class="mt-6 max-w-2xl text-base sm:text-lg text-slate-600 leading-relaxed">
        무료 보장 분석부터 신규 가입 상담까지. 영업시간 내 1시간 이내 응대 약속드립니다.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 grid gap-10 lg:grid-cols-2">
    <div>
      <h2 class="text-xl font-bold text-slate-900">연락처 안내</h2>
      <dl class="mt-6 space-y-5">
        <div class="rounded-xl border border-slate-200 p-5">
          <dt class="text-sm font-semibold text-slate-500">전화</dt>
          <dd class="mt-1 text-lg font-semibold text-slate-900">
            <a href={site.contact.phoneHref} class="hover:text-brand-700">{site.contact.phone}</a>
          </dd>
        </div>
        <div class="rounded-xl border border-slate-200 p-5">
          <dt class="text-sm font-semibold text-slate-500">이메일</dt>
          <dd class="mt-1 text-lg font-semibold text-slate-900">
            <a href={`mailto:${site.contact.email}`} class="hover:text-brand-700">{site.contact.email}</a>
          </dd>
        </div>
        <div class="rounded-xl border border-slate-200 p-5">
          <dt class="text-sm font-semibold text-slate-500">주소</dt>
          <dd class="mt-1 text-base text-slate-900">{site.contact.address}</dd>
        </div>
        <div class="rounded-xl border border-slate-200 p-5">
          <dt class="text-sm font-semibold text-slate-500">영업시간</dt>
          <dd class="mt-1 text-base text-slate-900 space-y-0.5">
            <div>{site.hours.weekday}</div>
            <div class="text-sm text-slate-500">{site.hours.lunch}</div>
            <div class="text-sm text-slate-500">{site.hours.weekend}</div>
          </dd>
        </div>
      </dl>
    </div>

    <div>
      <h2 class="text-xl font-bold text-slate-900">상담 신청</h2>
      <form class="mt-6 space-y-5" action={`mailto:${site.contact.email}`} method="post" enctype="text/plain">
        <div>
          <label for="name" class="block text-sm font-medium text-slate-700">이름 <span class="text-red-500">*</span></label>
          <input
            type="text"
            id="name"
            name="이름"
            required
            class="mt-1.5 block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-slate-700">연락처 <span class="text-red-500">*</span></label>
          <input
            type="tel"
            id="phone"
            name="연락처"
            required
            placeholder="010-0000-0000"
            class="mt-1.5 block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          />
        </div>
        <div>
          <label for="category" class="block text-sm font-medium text-slate-700">관심 분야</label>
          <select
            id="category"
            name="관심분야"
            class="mt-1.5 block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          >
            <option>보장 분석·리모델링</option>
            <option>생명보험</option>
            <option>건강·실손보험</option>
            <option>자동차보험</option>
            <option>사업자보험</option>
            <option>연금·저축</option>
            <option>기타</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-slate-700">문의 내용</label>
          <textarea
            id="message"
            name="문의내용"
            rows="5"
            class="mt-1.5 block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-200 focus:outline-none"
          ></textarea>
        </div>
        <label class="flex items-start gap-2 text-sm text-slate-600">
          <input type="checkbox" required class="mt-1 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
          <span>개인정보 수집·이용에 동의합니다. (상담 목적으로만 사용)</span>
        </label>
        <button
          type="submit"
          class="w-full rounded-full bg-brand-600 px-6 py-3 text-base font-semibold text-white hover:bg-brand-700 transition"
        >
          상담 신청하기
        </button>
        <p class="text-xs text-slate-500">
          * 본 양식은 이메일 클라이언트로 전달됩니다. 실제 운영 시 폼 처리 백엔드 연결 권장.
        </p>
      </form>
    </div>
  </section>
</Layout>
