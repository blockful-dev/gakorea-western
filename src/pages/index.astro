---
import Layout from "../layouts/Layout.astro";
import HeroBanner from "../components/HeroBanner.astro";
import TrustStats from "../components/TrustStats.astro";
import ProductGrid from "../components/ProductGrid.astro";
import QuickInquiryForm from "../components/QuickInquiryForm.astro";
import Testimonials from "../components/Testimonials.astro";
import NoticeSection from "../components/NoticeSection.astro";
import { site } from "../config/site";

const reasons = [
  {
    code: "01",
    title: "독립 비교",
    desc: "특정 보험사에 종속되지 않고 30+ 보험사 상품을 객관적으로 비교합니다.",
  },
  {
    code: "02",
    title: "전속 설계사 사후관리",
    desc: "가입 이후 청구·점검·보장 리뉴얼까지 한 명의 설계사가 평생 관리합니다.",
  },
  {
    code: "03",
    title: "수수료 투명 공개",
    desc: "수수료 구조와 권유 사유를 명시적으로 안내해 신뢰를 우선합니다.",
  },
];
---

<Layout description={site.description}>
  <HeroBanner />
  <TrustStats />
  <ProductGrid />

  <!-- Why us — minimal split -->
  <section class="py-20 sm:py-28 bg-white border-t border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600">
          ─ Why Us
        </p>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-brand-950 tracking-tight leading-[1.15]">
          왜 GA 인가,<br />
          왜 우리인가.
        </h2>
        <p class="mt-6 text-sm text-ink-500 leading-relaxed max-w-sm">
          한 회사의 상품만 권하는 전속 채널과 달리, GA는 시장 전체를 살펴 고객에게 가장 적절한 보장을 제안합니다.
          그 차이가, 가족의 30년 보장을 바꿉니다.
        </p>
      </div>

      <div class="lg:col-span-8 space-y-px bg-ink-100">
        {reasons.map((r) => (
          <div class="bg-white flex items-start gap-6 sm:gap-10 p-6 sm:p-8">
            <span class="num text-3xl sm:text-4xl font-bold text-accent-500 shrink-0 leading-none">
              {r.code}
            </span>
            <div>
              <h3 class="text-lg sm:text-xl font-bold text-brand-950">{r.title}</h3>
              <p class="mt-2 text-sm text-ink-600 leading-relaxed">{r.desc}</p>
            </div>
            <svg class="ml-auto shrink-0 h-5 w-5 text-ink-300 mt-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </div>
        ))}
      </div>
    </div>
  </section>

  <QuickInquiryForm />
  <Testimonials />
  <NoticeSection />

  <!-- Closing CTA strip -->
  <section class="relative overflow-hidden bg-brand-950 text-white">
    <div class="absolute inset-0 grid-texture opacity-50" aria-hidden="true"></div>
    <div
      class="absolute right-0 top-0 h-full w-1/2 opacity-30"
      style="background: radial-gradient(circle at top right, var(--color-accent-400) 0%, transparent 60%);"
      aria-hidden="true"
    ></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-300">
          Ready to plan?
        </p>
        <h2 class="mt-3 text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight leading-tight">
          오늘의 작은 점검이,<br />내일의 큰 안심이 됩니다.
        </h2>
      </div>
      <div class="flex flex-col sm:flex-row items-start gap-3">
        <a
          href="#inquiry"
          class="group inline-flex items-center gap-2 rounded-full bg-accent-500 px-7 py-3.5 text-sm font-bold text-white shadow-lg shadow-accent-900/40 hover:bg-accent-600 transition-colors"
        >
          무료 상담 신청
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
        <a
          href={site.contact.phoneHref}
          class="inline-flex items-center gap-2 rounded-full border border-white/30 px-7 py-3.5 text-sm font-semibold text-white hover:bg-white/10 transition-colors num"
        >
          {site.contact.phone}
        </a>
      </div>
    </div>
  </section>
</Layout>
