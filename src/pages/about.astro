---
import Layout from "../layouts/Layout.astro";
import { site } from "../config/site";
import logoManifest from "../config/logo-manifest.json";

const logos = logoManifest as Record<string, string>;

const milestones = [
  { year: "2018", text: "지에이코리아 본사 GA 출범" },
  { year: "2021", text: "웨스턴지사 개설 — 서울 강서권 거점 확장" },
  { year: "2023", text: "법인·개인사업자 컨설팅 본부 신설" },
  { year: "2025", text: "누적 상담 고객 5,000세대 돌파" },
];

const values = [
  { title: "고객 중심", desc: "수수료가 아닌 고객 보장의 적정성을 최우선으로." },
  { title: "투명한 비교", desc: "30+ 보험사 상품을 객관적 데이터로 비교 제시." },
  { title: "장기 동반", desc: "가입 이후의 청구·점검까지 책임지는 사후관리." },
];
---

<Layout title="회사소개" description={`${site.name} 회사소개. 서울 강서구에 위치한 GA 보험대리점.`}>
  <section class="bg-gradient-to-b from-brand-50 to-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-700">About Us</p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-bold text-slate-900">
        고객의 보장 그래프를<br />함께 그려갑니다
      </h1>
      <p class="mt-6 max-w-2xl text-base sm:text-lg text-slate-600 leading-relaxed">
        {site.name}는 30+ 국내 보험사의 상품을 비교·설계하는 GA(General Agency, 보험대리점)입니다.
        특정 보험사에 종속되지 않고, 오직 고객의 라이프스테이지에 가장 적합한 보장을 찾아드립니다.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">우리의 가치</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {values.map((v) => (
        <div class="rounded-2xl border border-slate-200 p-6">
          <h3 class="text-lg font-semibold text-slate-900">{v.title}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed">{v.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-700">Partners</p>
        <h2 class="mt-2 text-2xl sm:text-3xl font-bold text-slate-900">취급 보험사</h2>
        <p class="mt-3 text-slate-600 max-w-2xl mx-auto">
          국내 주요 30+ 보험사 상품을 한 자리에서 비교·설계합니다.
        </p>
      </div>

      <div class="mt-12">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider">생명보험</h3>
        <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {site.partners.life.map((p) => (
            <div class="flex items-center gap-2.5 rounded-xl bg-white border border-slate-200 h-16 px-3 hover:border-brand-300 transition">
              <img
                src={logos[p.slug] ?? `https://www.google.com/s2/favicons?domain=${p.domain}&sz=128`}
                alt=""
                loading="lazy"
                data-partner-name={p.name}
                class="h-7 w-7 shrink-0 object-contain rounded"
              />
              <span class="text-sm font-semibold text-slate-700 truncate">{p.name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-10">
        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider">손해보험</h3>
        <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {site.partners.nonlife.map((p) => (
            <div class="flex items-center gap-2.5 rounded-xl bg-white border border-slate-200 h-16 px-3 hover:border-brand-300 transition">
              <img
                src={logos[p.slug] ?? `https://www.google.com/s2/favicons?domain=${p.domain}&sz=128`}
                alt=""
                loading="lazy"
                data-partner-name={p.name}
                class="h-7 w-7 shrink-0 object-contain rounded"
              />
              <span class="text-sm font-semibold text-slate-700 truncate">{p.name}</span>
            </div>
          ))}
        </div>
      </div>

      <script>
        document.querySelectorAll<HTMLImageElement>("img[data-partner-name]").forEach((img) => {
          img.addEventListener("error", () => {
            img.style.display = "none";
          });
        });
      </script>

      <p class="mt-8 text-xs text-slate-500 text-center">
        * 위 보험사 리스트는 예시이며, 실제 제휴 보험사는 상담 시 안내드립니다.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">연혁</h2>
      <ol class="mt-10 space-y-6 border-l-2 border-brand-200 pl-6">
        {milestones.map((m) => (
          <li class="relative">
            <span class="absolute -left-[33px] top-1 inline-flex h-4 w-4 rounded-full bg-brand-600 ring-4 ring-white"></span>
            <div class="text-sm font-semibold text-brand-700">{m.year}</div>
            <p class="mt-1 text-slate-700">{m.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">오시는 길</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <a
        href={site.contact.naverMapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative block overflow-hidden rounded-2xl aspect-video bg-gradient-to-br from-emerald-50 via-emerald-100 to-emerald-200 ring-1 ring-emerald-200 hover:ring-emerald-400 transition"
        aria-label="네이버 지도에서 위치 보기"
      >
        <div class="absolute inset-0 opacity-30" aria-hidden="true">
          <svg viewBox="0 0 400 240" class="h-full w-full" preserveAspectRatio="none">
            <path d="M0 80 Q 100 60 200 90 T 400 70" stroke="#10b981" stroke-width="2" fill="none" />
            <path d="M0 140 Q 120 110 220 150 T 400 130" stroke="#10b981" stroke-width="2" fill="none" />
            <path d="M60 0 L 80 240" stroke="#10b981" stroke-width="1.5" />
            <path d="M280 0 L 260 240" stroke="#10b981" stroke-width="1.5" />
            <circle cx="100" cy="100" r="3" fill="#059669" />
            <circle cx="320" cy="160" r="3" fill="#059669" />
          </svg>
        </div>
        <div class="relative h-full flex flex-col items-center justify-center text-center p-6">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-emerald-600 shadow-lg group-hover:scale-110 transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C7.58 2 4 5.58 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.42-3.58-8-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/>
            </svg>
          </div>
          <p class="mt-3 text-sm font-semibold text-emerald-900">{site.contact.addressShort}</p>
          <p class="mt-0.5 text-xs text-emerald-700/80">대사빌딩 4층</p>
          <span class="mt-4 inline-flex items-center gap-1 rounded-full bg-white px-3 py-1.5 text-xs font-semibold text-emerald-700 shadow-sm group-hover:bg-emerald-600 group-hover:text-white transition">
            네이버 지도에서 길찾기
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17 17 7M7 7h10v10" />
            </svg>
          </span>
        </div>
      </a>
      <dl class="space-y-4 text-slate-700">
        <div>
          <dt class="text-sm font-semibold text-slate-500">주소</dt>
          <dd class="mt-1">{site.contact.address}</dd>
        </div>
        <div>
          <dt class="text-sm font-semibold text-slate-500">전화</dt>
          <dd class="mt-1"><a href={site.contact.phoneHref} class="text-brand-700 hover:underline">{site.contact.phone}</a></dd>
        </div>
        <div>
          <dt class="text-sm font-semibold text-slate-500">이메일</dt>
          <dd class="mt-1"><a href={`mailto:${site.contact.email}`} class="text-brand-700 hover:underline">{site.contact.email}</a></dd>
        </div>
        <div>
          <dt class="text-sm font-semibold text-slate-500">영업시간</dt>
          <dd class="mt-1">
            <ul class="space-y-1">
              <li>{site.hours.weekday}</li>
              <li>{site.hours.lunch}</li>
              <li>{site.hours.weekend}</li>
            </ul>
          </dd>
        </div>
      </dl>
    </div>
  </section>
</Layout>
