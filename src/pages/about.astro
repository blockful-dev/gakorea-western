---
import Layout from "../layouts/Layout.astro";
import PartnerLogoGrid from "../components/PartnerLogoGrid.astro";
import { site } from "../config/site";

const milestones = [
  { year: "2018", text: "지에이코리아 본사 GA 출범" },
  { year: "2021", text: "웨스턴지사 개설 — 서울 강서권 거점 확장" },
  { year: "2023", text: "법인·개인사업자 컨설팅 본부 신설" },
  { year: "2025", text: "누적 상담 고객 5,000세대 돌파" },
];

const values = [
  {
    code: "01",
    title: "고객 중심",
    desc: "수수료가 아닌 고객 보장의 적정성을 최우선으로 판단합니다.",
  },
  {
    code: "02",
    title: "투명한 비교",
    desc: "30+ 보험사 상품을 객관적 데이터로 비교하고 권유 사유를 명시합니다.",
  },
  {
    code: "03",
    title: "장기 동반",
    desc: "가입 이후의 청구·점검·갱신까지 한 명의 설계사가 책임집니다.",
  },
];

const principles = [
  "특정 보험사로부터 가입을 강요받지 않습니다",
  "수수료 구조와 권유 사유를 사전에 안내합니다",
  "현재 보유 보험의 적정성 점검은 무료입니다",
  "가입 후에도 분기 1회 보장 점검을 진행합니다",
];
---

<Layout title="회사소개" description={`${site.name} 회사소개. 서울 강서구에 위치한 GA 보험대리점.`}>
  <!-- About hero — editorial dark -->
  <section class="relative overflow-hidden bg-brand-950 text-white">
    <div class="absolute inset-0 grid-texture opacity-60" aria-hidden="true"></div>
    <div
      class="absolute -right-40 top-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full opacity-30 blur-3xl"
      style="background: radial-gradient(circle, var(--color-accent-400) 0%, transparent 60%);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-300">
        ─ About {site.shortName}
      </p>
      <div class="mt-6 grid lg:grid-cols-12 gap-10 items-end">
        <h1 class="lg:col-span-7 text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1]">
          한 명의 설계사가,<br />
          한 가족의 <span class="text-accent-300">30년</span>을<br />
          책임집니다.
        </h1>
        <p class="lg:col-span-5 text-base sm:text-lg text-brand-100/80 leading-relaxed">
          {site.name}는 30+ 국내 보험사의 상품을 비교·설계하는 GA(General Agency, 보험대리점)입니다.
          특정 보험사에 종속되지 않고, 오직 고객의 라이프스테이지에 가장 적합한 보장을 제안합니다.
        </p>
      </div>
    </div>

    <div class="relative border-t border-white/10">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-6 grid grid-cols-2 md:grid-cols-4 gap-6">
        <div>
          <div class="num text-2xl sm:text-3xl font-bold text-white">2018</div>
          <div class="mt-1 text-[11px] uppercase tracking-wider text-brand-200/70">설립</div>
        </div>
        <div>
          <div class="num text-2xl sm:text-3xl font-bold text-white">30<span class="text-accent-300">+</span></div>
          <div class="mt-1 text-[11px] uppercase tracking-wider text-brand-200/70">제휴 보험사</div>
        </div>
        <div>
          <div class="num text-2xl sm:text-3xl font-bold text-white">5,000<span class="text-accent-300">+</span></div>
          <div class="mt-1 text-[11px] uppercase tracking-wider text-brand-200/70">누적 상담세대</div>
        </div>
        <div>
          <div class="num text-2xl sm:text-3xl font-bold text-white">98<span class="text-accent-300">%</span></div>
          <div class="mt-1 text-[11px] uppercase tracking-wider text-brand-200/70">고객 만족도</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-12 mb-14">
        <div class="lg:col-span-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600">
            ─ Our Values
          </p>
          <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-brand-950 tracking-tight leading-tight">
            우리가 일하는<br />
            세 가지 원칙
          </h2>
        </div>
        <p class="lg:col-span-7 text-base text-ink-500 leading-relaxed lg:pt-3">
          GA는 단지 여러 보험사 상품을 파는 채널이 아닙니다. 시장 전체를 살펴 고객에게 맞는 보장을
          설계하고, 가입 이후까지 책임지는 일이 우리가 정의하는 GA의 역할입니다.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-px bg-ink-100 border border-ink-100">
        {values.map((v) => (
          <div class="bg-white p-8 sm:p-10 group hover:bg-brand-50/30 transition-colors">
            <div class="flex items-start justify-between">
              <span class="num text-5xl sm:text-6xl font-bold text-accent-500/90">{v.code}</span>
              <svg class="h-5 w-5 text-ink-300 group-hover:text-brand-700 group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 6l6 6-6 6"/>
              </svg>
            </div>
            <h3 class="mt-10 text-xl font-bold text-brand-950">{v.title}</h3>
            <p class="mt-3 text-sm text-ink-600 leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Promise -->
  <section class="py-20 sm:py-24 bg-ink-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-5">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600">
          ─ Promise
        </p>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-brand-950 tracking-tight leading-tight">
          고객에게 드리는<br />네 가지 약속
        </h2>
      </div>
      <ul class="lg:col-span-7 space-y-3">
        {principles.map((p, i) => (
          <li class="flex items-start gap-4 bg-white rounded-xl border border-ink-100 px-6 py-5">
            <span class="num shrink-0 inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-900 text-accent-300 text-xs font-bold">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="text-sm sm:text-base font-medium text-ink-800 pt-1">{p}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <PartnerLogoGrid />

  <!-- History -->
  <section class="py-20 sm:py-28 bg-ink-50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600">
          ─ History
        </p>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-brand-950 tracking-tight">
          걸어온 길
        </h2>
      </div>

      <div class="relative">
        <div class="hidden md:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px bg-ink-200" aria-hidden="true"></div>
        <ol class="space-y-10 md:space-y-14">
          {milestones.map((m, i) => (
            <li class={`md:grid md:grid-cols-2 md:gap-12 items-center`}>
              <div class={i % 2 === 0 ? "md:text-right md:pr-8" : "md:pl-8 md:order-2"}>
                <div class="num text-4xl sm:text-5xl font-bold text-brand-900">{m.year}</div>
                <p class="mt-3 text-base text-ink-700 leading-relaxed">{m.text}</p>
              </div>
              <div class={`hidden md:flex items-center justify-center relative ${i % 2 === 0 ? "" : "md:order-1"}`}>
                <span class="inline-block h-3.5 w-3.5 rounded-full bg-accent-500 ring-4 ring-ink-50 relative z-10"></span>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Office / Map -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-5">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600">
          ─ Office
        </p>
        <h2 class="mt-4 text-3xl sm:text-4xl font-bold text-brand-950 tracking-tight leading-tight">
          오시는 길
        </h2>
        <p class="mt-6 text-base text-ink-500 leading-relaxed">
          {site.contact.address}<br />
          상담은 사전 예약을 권장드립니다.
        </p>

        <dl class="mt-10 space-y-5">
          <div class="flex gap-4 pb-5 border-b border-ink-100">
            <dt class="w-20 shrink-0 text-xs font-semibold uppercase tracking-wider text-ink-400 pt-0.5">주소</dt>
            <dd class="text-sm text-ink-800 leading-relaxed">{site.contact.address}</dd>
          </div>
          <div class="flex gap-4 pb-5 border-b border-ink-100">
            <dt class="w-20 shrink-0 text-xs font-semibold uppercase tracking-wider text-ink-400 pt-0.5">전화</dt>
            <dd class="text-sm">
              <a href={site.contact.phoneHref} class="num text-brand-800 hover:text-accent-500 font-semibold">{site.contact.phone}</a>
            </dd>
          </div>
          <div class="flex gap-4 pb-5 border-b border-ink-100">
            <dt class="w-20 shrink-0 text-xs font-semibold uppercase tracking-wider text-ink-400 pt-0.5">이메일</dt>
            <dd class="text-sm">
              <a href={`mailto:${site.contact.email}`} class="text-brand-800 hover:text-accent-500 font-semibold">{site.contact.email}</a>
            </dd>
          </div>
          <div class="flex gap-4">
            <dt class="w-20 shrink-0 text-xs font-semibold uppercase tracking-wider text-ink-400 pt-0.5">영업시간</dt>
            <dd class="text-sm text-ink-700 space-y-1">
              <div>{site.hours.weekday}</div>
              <div class="text-ink-500">{site.hours.lunch}</div>
              <div class="text-ink-500">{site.hours.weekend}</div>
            </dd>
          </div>
        </dl>
      </div>

      <a
        href={site.contact.naverMapUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="lg:col-span-7 group relative block overflow-hidden rounded-2xl aspect-[4/3] sm:aspect-video bg-brand-950 ring-1 ring-brand-800 hover:ring-accent-400 transition"
        aria-label="네이버 지도에서 위치 보기"
      >
        <div class="absolute inset-0 grid-texture opacity-40" aria-hidden="true"></div>
        <svg viewBox="0 0 400 300" class="absolute inset-0 h-full w-full opacity-50" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
          <defs>
            <linearGradient id="r" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="var(--color-brand-400)" stop-opacity="0.4"/>
              <stop offset="1" stop-color="var(--color-brand-400)" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <path d="M0 100 Q 100 80 200 110 T 400 90" stroke="var(--color-brand-400)" stroke-width="1.2" fill="none" opacity="0.6"/>
          <path d="M0 180 Q 120 150 220 190 T 400 170" stroke="var(--color-brand-400)" stroke-width="1.2" fill="none" opacity="0.6"/>
          <path d="M0 230 Q 80 215 200 235 T 400 220" stroke="var(--color-brand-400)" stroke-width="1.2" fill="none" opacity="0.6"/>
          <path d="M70 0 L 95 300" stroke="var(--color-brand-400)" stroke-width="1" opacity="0.5"/>
          <path d="M180 0 L 205 300" stroke="var(--color-brand-400)" stroke-width="1" opacity="0.5"/>
          <path d="M310 0 L 290 300" stroke="var(--color-brand-400)" stroke-width="1" opacity="0.5"/>
          <circle cx="200" cy="150" r="120" fill="url(#r)"/>
        </svg>
        <div class="relative h-full flex flex-col items-center justify-center text-center p-8">
          <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-accent-500 shadow-2xl shadow-accent-900/40 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C7.58 2 4 5.58 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.42-3.58-8-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/>
            </svg>
          </div>
          <p class="mt-5 text-sm font-semibold text-white">{site.contact.addressShort}</p>
          <p class="mt-1 text-xs text-brand-200/70">대사빌딩 4층</p>
          <span class="mt-6 inline-flex items-center gap-1.5 rounded-full bg-white px-4 py-2 text-xs font-bold text-brand-900 group-hover:bg-accent-500 group-hover:text-white transition-colors">
            네이버 지도에서 길찾기
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17 17 7M7 7h10v10"/>
            </svg>
          </span>
        </div>
      </a>
    </div>
  </section>
</Layout>
