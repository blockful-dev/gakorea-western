---
import { site } from "../config/site";
---

<aside
  class="hidden lg:flex fixed right-5 top-1/2 -translate-y-1/2 z-30 flex-col gap-2 bg-white rounded-2xl border border-ink-100 shadow-[0_20px_60px_-20px_rgba(15,32,64,0.25)] p-2"
  aria-label="빠른 메뉴"
>
  <a
    href={site.contact.phoneHref}
    class="group flex flex-col items-center justify-center w-16 h-16 rounded-xl hover:bg-brand-900 transition-colors"
    aria-label="전화 상담"
  >
    <svg class="h-5 w-5 text-brand-700 group-hover:text-accent-300 transition-colors" viewBox="0 0 24 24" fill="currentColor">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
    </svg>
    <span class="mt-1 text-[10px] font-semibold text-ink-600 group-hover:text-white transition-colors">전화</span>
  </a>

  <a
    href="#inquiry"
    class="group flex flex-col items-center justify-center w-16 h-16 rounded-xl bg-accent-500 hover:bg-accent-600 transition-colors"
    aria-label="상담 신청"
  >
    <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <span class="mt-1 text-[10px] font-semibold text-white">상담</span>
  </a>

  <a
    href={site.contact.naverMapUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="group flex flex-col items-center justify-center w-16 h-16 rounded-xl hover:bg-brand-900 transition-colors"
    aria-label="오시는 길"
  >
    <svg class="h-5 w-5 text-brand-700 group-hover:text-accent-300 transition-colors" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2C7.58 2 4 5.58 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.42-3.58-8-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/>
    </svg>
    <span class="mt-1 text-[10px] font-semibold text-ink-600 group-hover:text-white transition-colors">오시는길</span>
  </a>

  <div class="border-t border-ink-100 my-1"></div>

  <button
    id="scroll-top-btn"
    type="button"
    class="group flex flex-col items-center justify-center w-16 h-14 rounded-xl hover:bg-ink-100 transition-colors"
    aria-label="맨 위로"
  >
    <svg class="h-4 w-4 text-ink-500 group-hover:text-brand-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
    <span class="mt-0.5 text-[10px] font-semibold text-ink-500 group-hover:text-brand-700">TOP</span>
  </button>
</aside>

<script>
  document.getElementById("scroll-top-btn")?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
