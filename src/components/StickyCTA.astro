---
import { site } from "../config/site";

const kakaoUrl = site.contact.kakaoChannelId
  ? `https://pf.kakao.com/_${site.contact.kakaoChannelId}`
  : null;
---

<div class="md:hidden fixed bottom-0 inset-x-0 z-30 bg-white/95 backdrop-blur border-t border-ink-100 px-4 py-3 shadow-[0_-8px_30px_-8px_rgba(15,32,64,0.18)]">
  <div class="flex gap-2">
    <a
      href={site.contact.phoneHref}
      class="flex-1 inline-flex items-center justify-center gap-2 rounded-xl bg-brand-950 px-4 py-3.5 text-sm font-bold text-white hover:bg-brand-900 transition-colors num"
      aria-label="전화 상담"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-300" viewBox="0 0 24 24" fill="currentColor">
        <path d="M3 5.5C3 4.12 4.12 3 5.5 3h1.81c.86 0 1.62.55 1.89 1.36l1.06 3.16a2 2 0 0 1-.45 2.04l-1.27 1.27a13 13 0 0 0 5.13 5.13l1.27-1.27a2 2 0 0 1 2.04-.45l3.16 1.06a2 2 0 0 1 1.36 1.89V18.5c0 1.38-1.12 2.5-2.5 2.5C10.6 21 3 13.4 3 5.5Z"/>
      </svg>
      전화 상담
    </a>
    {kakaoUrl ? (
      <a
        href={kakaoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 inline-flex items-center justify-center gap-2 rounded-xl bg-yellow-400 px-4 py-3.5 text-sm font-bold text-slate-900 hover:bg-yellow-300 transition-colors"
        aria-label="카카오톡 상담"
      >
        카톡 상담
      </a>
    ) : (
      <a
        href="/contact"
        class="flex-1 inline-flex items-center justify-center gap-2 rounded-xl bg-accent-500 px-4 py-3.5 text-sm font-bold text-white hover:bg-accent-600 transition-colors"
      >
        무료 상담 신청
      </a>
    )}
  </div>
</div>
