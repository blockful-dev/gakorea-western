---
import { site } from "../config/site";

const interests = ["건강·실손", "암·중대질병", "자동차", "연금·저축", "종신·정기", "법인·사업자"];
---

<section id="inquiry" class="relative py-20 sm:py-28 bg-brand-50 overflow-hidden">
  <div
    class="absolute inset-0 opacity-30"
    style="background-image: radial-gradient(var(--color-brand-200) 1px, transparent 1px); background-size: 24px 24px;"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- Left: copy -->
      <div class="lg:pt-6">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-600">
          ─ Free Consultation
        </p>
        <h2 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-950 tracking-tight leading-[1.15]">
          연락처만 남겨주세요.<br />
          <span class="text-brand-700">전속 설계사가</span> 회신드립니다.
        </h2>
        <p class="mt-6 text-base text-ink-600 max-w-md leading-relaxed">
          상담료 없이, 가입 강요 없이. 현재 보유한 보장의 적정성을 점검해드리고
          필요한 경우에만 30+ 보험사 상품을 객관적으로 비교 제시합니다.
        </p>

        <dl class="mt-10 space-y-5 max-w-md">
          <div class="flex items-start gap-4">
            <div class="num shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-900 text-accent-300 text-sm font-bold">01</div>
            <div>
              <dt class="font-semibold text-brand-950">신청 접수</dt>
              <dd class="mt-1 text-sm text-ink-500">평일 09–18시 내 1시간 이내 회신</dd>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="num shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-900 text-accent-300 text-sm font-bold">02</div>
            <div>
              <dt class="font-semibold text-brand-950">보장 진단</dt>
              <dd class="mt-1 text-sm text-ink-500">현재 가입 보험의 중복·누락 항목 점검</dd>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="num shrink-0 inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-900 text-accent-300 text-sm font-bold">03</div>
            <div>
              <dt class="font-semibold text-brand-950">맞춤 설계</dt>
              <dd class="mt-1 text-sm text-ink-500">최대 3개사 비교안 동시 제공</dd>
            </div>
          </div>
        </dl>
      </div>

      <!-- Right: form card -->
      <div class="relative">
        <div class="absolute -top-4 -right-4 w-32 h-32 bg-accent-200 rounded-full blur-3xl opacity-50" aria-hidden="true"></div>
        <form
          action={`mailto:${site.contact.email}`}
          method="post"
          enctype="text/plain"
          class="relative bg-white rounded-3xl shadow-[0_40px_80px_-30px_rgba(15,32,64,0.25)] border border-white p-7 sm:p-9"
        >
          <div class="flex items-center justify-between mb-7">
            <h3 class="text-xl font-bold text-brand-950">무료 보장분석 신청</h3>
            <span class="text-[10px] uppercase tracking-[0.18em] text-accent-600 font-semibold">3 fields</span>
          </div>

          <div class="space-y-5">
            <div>
              <label for="q-name" class="block text-xs font-semibold uppercase tracking-wider text-ink-500 mb-2">
                성함
              </label>
              <input
                id="q-name"
                name="name"
                type="text"
                required
                placeholder="홍길동"
                class="w-full border-0 border-b-2 border-ink-200 focus:border-brand-700 focus:ring-0 px-0 py-2 text-base bg-transparent transition-colors"
              />
            </div>
            <div>
              <label for="q-phone" class="block text-xs font-semibold uppercase tracking-wider text-ink-500 mb-2">
                연락처
              </label>
              <input
                id="q-phone"
                name="phone"
                type="tel"
                required
                placeholder="010-0000-0000"
                class="w-full border-0 border-b-2 border-ink-200 focus:border-brand-700 focus:ring-0 px-0 py-2 text-base bg-transparent transition-colors num"
              />
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-ink-500 mb-3">
                관심 상품
              </label>
              <div class="flex flex-wrap gap-2">
                {interests.map((tag) => (
                  <label class="cursor-pointer">
                    <input type="checkbox" name="interest" value={tag} class="peer sr-only" />
                    <span class="inline-block rounded-full border border-ink-200 px-3.5 py-1.5 text-xs font-medium text-ink-600 hover:border-brand-400 hover:text-brand-700 peer-checked:bg-brand-900 peer-checked:text-white peer-checked:border-brand-900 transition-colors">
                      {tag}
                    </span>
                  </label>
                ))}
              </div>
            </div>
          </div>

          <button
            type="submit"
            class="mt-8 group w-full inline-flex items-center justify-center gap-2 rounded-full bg-accent-500 px-7 py-4 text-sm font-bold text-white shadow-lg shadow-accent-500/30 hover:bg-accent-600 transition-colors"
          >
            상담 신청 보내기
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </button>

          <p class="mt-4 text-[11px] text-ink-400 leading-relaxed text-center">
            개인정보는 상담 회신 목적으로만 사용되며, 동의 없이 제3자에게 제공되지 않습니다.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
